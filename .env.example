# Copy this file to ".env" and fill in real values. Never commit ".env".

# Gemini -- get a free key at https://aistudio.google.com/apikey. Set both
# keys to the same value; the google-genai client prefers GOOGLE_API_KEY
# over GEMINI_API_KEY when both are present.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GEMINI_MODEL=gemini-2.5-flash

# Email-to-SMS carrier gateway, used for the patient confirmation SMS. Set
# to the test recipient's carrier gateway domain if known, e.g.
# "tmomail.net" for T-Mobile/Mint/Metro, "vtext.com" for Verizon,
# "txt.att.net" for AT&T. Leave blank to broadcast to all major carriers
# instead (works for unknown numbers, less precise).
SMS_GATEWAY_DOMAIN=

# Google Maps (used by clinic_search_skill; MCP server is primary, this key
# backs the direct Places API fallback in tools/maps_tool.py)
GOOGLE_MAPS_API_KEY=

# Google Sheets (accessed via the google-sheets MCP server; the service
# account path for that server is set in .agents/mcp_config.json, not here).
# Bookings are always logged locally too (data/bookings_log.json); user
# intake and clinic-search logging only happen if this ID is set.
GOOGLE_SHEETS_SPREADSHEET_ID=

# IP geolocation fallback for clinic_search_skill when location is missing.
# Optional -- falls back to the free ipapi.co tier if unset.
IPGEOLOCATION_API_KEY=

# Test patient contact used by the functional test page / demo pipeline.
TEST_PATIENT_EMAIL=
FALLBACK_CLINIC_EMAIL=

# Flask
FLASK_PORT=5000
FLASK_DEBUG=true
