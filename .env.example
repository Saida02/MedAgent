# Copy this file to ".env" and fill in real values. Never commit ".env".

# Gemini -- get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Twilio (direct API, used for the patient confirmation SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email-to-SMS carrier gateway (simpler alternative to Twilio A2P/toll-free
# registration). Set to the test recipient's carrier gateway domain if
# known, e.g. "tmomail.net" for T-Mobile/Mint/Metro, "vtext.com" for
# Verizon, "txt.att.net" for AT&T. Leave blank to broadcast to all major
# carriers instead (works for unknown numbers, less precise).
SMS_GATEWAY_DOMAIN=

# Google Maps (used by clinic_search_skill; MCP server is primary, this key
# backs the direct Places API fallback in tools/maps_tool.py)
GOOGLE_MAPS_API_KEY=

# Google Sheets (MCP server is primary; set a spreadsheet ID to log bookings
# there instead of the local data/bookings_log.json fallback)
GOOGLE_SERVICE_ACCOUNT_PATH=.agents/your-google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# Gmail SMTP (used for sending booking emails and, optionally, as the
# email-to-SMS gateway sender). Use a Gmail "app password", not your normal
# account password: https://myaccount.google.com/apppasswords
GMAIL_SMTP_ADDRESS=
GMAIL_SMTP_APP_PASSWORD=

# IP geolocation fallback for clinic_search_skill when location is missing.
# Optional -- falls back to the free ipapi.co tier if unset.
IPGEOLOCATION_API_KEY=

# Test patient contact used by the functional test page / demo pipeline.
TEST_PATIENT_EMAIL=
TEST_PATIENT_PHONE=
FALLBACK_CLINIC_EMAIL=

# Flask
FLASK_PORT=5000
FLASK_DEBUG=true
